doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NYONDO Hardware | Reset Password
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/login.css')

.container.d-flex.justify-content-center.align-items-center.vh-100
  .card.shadow-lg.p-4.login-card
    h2.text-center.mb-3.text-warning NYONDO Hardware
    p.text-center.text-secondary.mb-4 Hardware Management System
    
    if error
      .alert.alert-danger= error
    
    form(action=`/reset-password/${token}` method='post')
      .mb-3
        label.form-label(for='password') New Password
        input#password.form-control(type='password' name='password' placeholder='Enter new password' required)
      .mb-3
        label.form-label(for='confirmPassword') Confirm Password
        input#confirmPassword.form-control(type='password' name='confirmPassword' placeholder='Confirm new password' required)
      .d-grid.mb-3
        button.btn.btn-warning(type='submit') Reset Password
      .text-center
        a.text-decoration-none.text-info(href='/login') Back to Login

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
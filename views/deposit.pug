doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Deposit Scheme
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='#') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.text-danger(href='admin') Back

.container-fluid.mt-4
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning Deposit Scheme Management
    .text-muted= new Date().toLocaleDateString()

  if error
    .alert.alert-danger= error
  if success
    .alert.alert-success= success

  // Add Deposit Form
  .card.mb-4
    .card-header Register New Customer Deposit
    .card-body
      form(action='/deposits/add' method='POST')
        .row
          .col-md-3.mb-3
            label.form-label Customer Name
            input.form-control(type='text' name='customerName' required)
          .col-md-3.mb-3
            label.form-label Phone Number
            input.form-control(type='tel' name='customerPhone' placeholder='+256712345678' required)
          .col-md-3.mb-3
            label.form-label NIN Number
            input.form-control(type='text' name='ninNumber' required)
          .col-md-3.mb-3
            label.form-label Deposit Amount (UGX)
            input.form-control(type='number' name='amount' required)
          .col-md-12.mt-2
            button.btn.btn-gold(type='submit') Register Deposit

  // Deposits Table
  .card
    .card-header.d-flex.justify-content-between
      span Customer Deposits
      button.btn.btn-sm.btn-gold(onclick='window.print()') Print
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Date
              th Customer Name
              th Phone
              th NIN
              th Total Deposited
              th Used
              th Balance
              th Status
              th Action
          tbody
            if deposits && deposits.length > 0
              each deposit in deposits
                tr
                  td= deposit.createdAt ? deposit.createdAt.toLocaleDateString() : 'N/A'
                  td= deposit.customerName
                  td= deposit.customerPhone
                  td= deposit.ninNumber
                  td= 'UGX ' + deposit.totalDeposited.toLocaleString()
                  td= 'UGX ' + deposit.amountUsed.toLocaleString()
                  td= 'UGX ' + deposit.balance.toLocaleString()
                  td
                    if deposit.status === 'active'
                      span.badge.bg-success Active
                    else
                      span.badge.bg-secondary Completed
                  td
                    form(action='/deposits/use' method='POST' style='display: inline-block;')
                      input(type='hidden' name='id' value=deposit._id)
                      input(type='number' name='amount' placeholder='Amount' style='width: 100px;' required)
                      button.btn.btn-sm.btn-warning(type='submit') Use
                    a.btn.btn-sm.btn-danger(href=`/deposits/delete/${deposit._id}` onclick='return confirm("Delete this deposit record?")') Delete
            else
              tr
                td(colspan='9', class='text-center text-muted') No deposit records yet

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
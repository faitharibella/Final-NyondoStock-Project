doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Deposit Scheme
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='#') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.text-danger(href='admin') Back

.container-fluid.mt-4
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning Deposit Scheme Management
    .text-muted= new Date().toLocaleDateString()

  if error
    .alert.alert-danger= error
  if success
    .alert.alert-success= success

  // Add Deposit Form
  .card.mb-4
    .card-header Register New Customer Deposit
    .card-body
      form(action='/deposit/add' method='POST')
        .row
          .col-md-3.mb-3
            label.form-label(for='customerName') Customer Name
            input#customerName.form-control(type='text' name='customerName' required)
          .col-md-3.mb-3
            label.form-label(for='customerPhone') Phone Number
            input#customerPhone.form-control(type='tel' name='customerPhone' placeholder='+256712345678' required)
          .col-md-3.mb-3
            label.form-label(for='ninNumber') NIN Number
            input#ninNumber.form-control(type='text' name='ninNumber' required)
          .col-md-3.mb-3
            label.form-label(for='amount') Deposit Amount (UGX)
            input#amount.form-control(type='number' name='amount' required)
          .col-md-12.mt-2
            button.btn.btn-gold(type='submit') Register Deposit

  // Deposits Table
  .card
    .card-header.d-flex.justify-content-between
      span Customer Deposits
      button.btn.btn-sm.btn-gold(onclick='window.print()') Print
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Date
              th Customer Name
              th Phone
              th NIN
              th Total Deposited
              th Used
              th Balance
              th Status
              th Action
          tbody
            if deposit && deposit.length > 0
              each record in deposit
                tr
                  td= record.createdAt ? record.createdAt.toLocaleDateString() : 'N/A'
                  td= record.customerName
                  td= record.customerPhone
                  td= record.ninNumber
                  td= 'UGX ' + record.totalDeposited.toLocaleString()
                  td= 'UGX ' + (record.amountUsed || 0).toLocaleString()
                  td= 'UGX ' + record.balance.toLocaleString()
                  td
                    if record.status === 'active'
                      span.badge.bg-success Active
                    else
                      span.badge.bg-secondary Completed
                  td
                    button.btn.btn-sm.btn-warning(type='submit' formaction='/deposit/use' formmethod='POST' name='id' value=record._id) Use
                    a.btn.btn-sm.btn-danger.ms-1(href=`/deposit/delete/${record._id}` onclick='return confirm("Delete this deposit record?")') Delete
            else
              tr
                td(colspan='9', class='text-center text-muted') No deposit records yet

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
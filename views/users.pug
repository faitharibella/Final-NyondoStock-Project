doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - User Management
  // Bootstrap 5
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

// Navbar
nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning(href='#') NyondoStock - User Management
    button.btn.btn-gold.ms-auto(onclick="window.location.href = 'admin'") ← Back to Dashboard

// Page Header
.container.mt-4
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning  User Management
    button.btn.btn-gold(data-bs-toggle='modal' data-bs-target='#addUserModal') + Add New User

// Success/Error Messages
if success
  .alert.alert-success.alert-dismissible.fade-show
    = success
    button.btn-close(type='button' data-bs-dismiss='alert')
if error
  .alert.alert-danger.alert-dismissible.fade-show
    = error
    button.btn-close(type='button' data-bs-dismiss='alert')

// Search & Filter
.row.mb-4
  .col-md-6.mb-2
    form(action='/users/search' method='GET')
      .input-group
        input.form-control(type='text' name='search' placeholder='🔍 Search by name or email...' value=searchTerm)
        button.btn.btn-gold(type='submit') Search
  .col-md-6.mb-2
    form(action='/users/filter' method='GET')
      .input-group
        select.form-select(name='role' onchange='this.form.submit()')
          option(value='All' selected=(filterRole === 'All')) All Roles
          option(value='Admin' selected=(filterRole === 'Admin')) Admin
          option(value='Manager' selected=(filterRole === 'Manager')) Manager
          option(value='Salesperson' selected=(filterRole === 'Salesperson')) Salesperson

// Users Table
.table-responsive
  table.table.table-dark.table-hover.align-middle
    thead
      tr
        th Name
        th Email
        th Role
        th Status
        th Actions
    tbody#usersTableBody
      //-  Display users from database
      if users && users.length > 0
        each user in users
          tr
            td= user.fullname
            td= user.email
            td
              if user.role === 'Admin'
                span.badge.bg-warning.text-dark Admin
              else if user.role === 'Manager'
                span.badge.bg-info Manager
              else
                span.badge.bg-secondary Salesperson
            td
              if user.status === 'active'
                span.badge.bg-success Active
              else
                span.badge.bg-danger Inactive
            td
              button.btn.btn-sm.btn-gold(onclick=`openEditModal('${user._id}', '${user.fullname}', '${user.email}', '${user.role}', '${user.status}')`) Edit
              button.btn.btn-sm.btn-danger.ms-1(onclick=`deleteUser('${user._id}')`) Delete
      else
        tr
          td(colspan='5', class='text-center text-muted') No users found. Click "Add New User" to create one.

// Add User Modal
#addUserModal.modal.fade(tabindex='-1')
  .modal-dialog
    .modal-content.bg-dark.text-white
      .modal-header
        h5.modal-title.text-warning  Add New User
        button.btn-close.btn-close-white(type='button' data-bs-dismiss='modal')
      .modal-body
        form(action='/users' method='POST')
          .mb-3
            label.form-label Full Name *
            input.form-control.bg-dark.text-white.border-secondary(type='text' name='fullname' required)
          .mb-3
            label.form-label Email Address *
            input.form-control.bg-dark.text-white.border-secondary(type='email' name='email' required)
          .mb-3
            label.form-label Phone
            input.form-control.bg-dark.text-white.border-secondary(type='tel' name='phone' placeholder='07XX XXX XXX')
          .mb-3
            label.form-label Password *
            input.form-control.bg-dark.text-white.border-secondary(type='password' name='password' required)
          .mb-3
            label.form-label Role *
            select.form-select.bg-dark.text-white.border-secondary(name='role' required)
              option(value='Admin') Admin
              option(value='Manager') Manager
              option(value='Salesperson') Salesperson
          .mb-3
            label.form-label Status *
            select.form-select.bg-dark.text-white.border-secondary(name='status' required)
              option(value='active') Active
              option(value='inactive') Inactive
          .modal-footer
            button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Cancel
            button.btn.btn-gold(type='submit') Add User

// Edit User Modal
#editUserModal.modal.fade(tabindex='-1')
  .modal-dialog
    .modal-content.bg-dark.text-white
      .modal-header
        h5.modal-title.text-warning  Edit User
        button.btn-close.btn-close-white(type='button' data-bs-dismiss='modal')
      .modal-body
        form(id='editUserForm' action='/users/edit' method='POST')
          input(type='hidden' name='id' id='editUserId')
          .mb-3
            label.form-label Full Name
            input.form-control.bg-dark.text-white.border-secondary(type='text' name='fullname' id='editUserName' required)
          .mb-3
            label.form-label Email Address
            input.form-control.bg-dark.text-white.border-secondary(type='email' name='email' id='editUserEmail' required)
          .mb-3
            label.form-label Role
            select.form-select.bg-dark.text-white.border-secondary(name='role' id='editUserRole' required)
              option(value='Admin') Admin
              option(value='Manager') Manager
              option(value='Salesperson') Salesperson
          .mb-3
            label.form-label Status
            select.form-select.bg-dark.text-white.border-secondary(name='status' id='editUserStatus' required)
              option(value='active') Active
              option(value='inactive') Inactive
          .modal-footer
            button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Cancel
            button.btn.btn-gold(type='submit') Save Changes

// Delete Form (hidden)
form#deleteUserForm(action='/users/delete' method='POST' style='display: none;')
  input(type='hidden' name='id' id='deleteUserId')

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')

// Minimal JS for modals (only to populate data)
script.
  function openEditModal(id, fullname, email, role, status) {
    document.getElementById('editUserId').value = id;
    document.getElementById('editUserName').value = fullname;
    document.getElementById('editUserEmail').value = email;
    document.getElementById('editUserRole').value = role;
    document.getElementById('editUserStatus').value = status.toLowerCase();
    new bootstrap.Modal(document.getElementById('editUserModal')).show();
  }
  
  function deleteUser(id) {
    if (confirm('Are you sure you want to delete this user?')) {
      document.getElementById('deleteUserId').value = id;
      document.getElementById('deleteUserForm').submit();
    }
  }
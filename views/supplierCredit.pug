doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Supplier Credit
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

// Navbar
nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='#') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.text-danger(href='admin') Back

.container-fluid.mt-4
  // Page Header
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning Supplier Credit Management
    .text-muted= new Date().toLocaleDateString()

  // Stats Cards
  .row.g-4.mb-4
    .col-md-3
      .card.stat-card.text-center
        h6 Total Owed
        .stat-number.text-danger UGX #{totalOwed}
    .col-md-3
      .card.stat-card.text-center
        h6 Overdue Payments
        .stat-number.text-warning UGX #{totalOverdue}
    .col-md-3
      .card.stat-card.text-center
        h6 Paid This Month
        .stat-number.text-success UGX #{totalPaidThisMonth}
    .col-md-3
      .card.stat-card.text-center
        h6 Active Suppliers
        .stat-number #{activeSuppliers}

  // Supplier Credit Table - Fixed to use Stock fields
  .card
    .card-header.d-flex.justify-content-between
      span Supplier Credit Records
      button.btn.btn-sm.btn-gold(onclick='window.print()') Print
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Date
              th Supplier
              th Product
              th Amount Owed
              th Status
              th Action
          tbody
            if credits && credits.length > 0
              each credit in credits
                tr
                  td= credit.date ? credit.date.toLocaleDateString() : 'N/A'
                  td= credit.supplierName
                  td= credit.productName
                  td= 'UGX ' + (credit.unitCost * credit.quantity).toLocaleString()
                  td
                    if credit.paymentStatus === 'cash'
                      span.badge.bg-success Paid
                    else
                      span.badge.bg-warning.text-dark Pending
                  td
                    if credit.paymentStatus !== 'cash'
                      form(action='/supplier-credit/pay' method='POST')
                       input(type='hidden' name='id' value=credit._id)
                       button.btn.btn-sm.btn-gold(type='submit') Mark as Paid
            else
              tr
                td(colspan='6', class='text-center text-muted') No supplier credit records yet

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Sales History
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='#') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.text-danger(href='salesperson') Back

.container-fluid.mt-4
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning My Sales History
    .text-muted= new Date().toLocaleDateString()

  .card
    .card-header.d-flex.justify-content-between
      span All Sales Records
      button.btn.btn-sm.btn-gold(onclick='window.print()') Print
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Date
              th Time
              th Customer
              th Product
              th Quantity
              th Total Amount
              th Payment Method
              th Receipt
          tbody
            if sales && sales.length > 0
              each sale in sales
                tr
                  td= sale.createdAt ? sale.createdAt.toLocaleDateString() : 'N/A'
                  td= sale.createdAt ? sale.createdAt.toLocaleTimeString() : 'N/A'
                  td= sale.customerName
                  td= sale.productName
                  td= sale.quantity
                  td= 'UGX ' + sale.totalamount.toLocaleString()
                  td= sale.paymentMethod
                  td
                    a.btn.btn-sm.btn-gold(href=`/receipt/${sale._id}`) View
            else
              tr
                td(colspan='8', class='text-center text-muted') No sales records found

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
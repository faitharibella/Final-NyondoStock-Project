doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Receipt
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/receipt.css')

body
  .receipt-card
    .receipt-header
      h4 NYONDO General Hardware LTD
      p Nansana, Kampala - Uganda
      p Tel: +256 712 345 678
    
    .receipt-body
      .info-row
        span.info-label CUSTOMER
        span.info-value #{sale.customerName}
      
      .info-row
        span.info-label PRODUCT
        span.info-value #{sale.productName}
      
      .info-row
        span.info-label QUANTITY
        span.info-value #{sale.quantity}
      
      .info-row
        span.info-label UNIT PRICE
        span.info-value UGX #{sale.unitprice ? sale.unitprice.toLocaleString() : 0}
      
      if sale.transportFee > 0
        .info-row
          span.info-label TRANSPORT FEE
          span.info-value UGX #{sale.transportFee.toLocaleString()}
      
      hr
      
      .total-section
        .total-row
          span.total-label TOTAL AMOUNT
          span.total-amount UGX #{sale.totalamount ? sale.totalamount.toLocaleString() : 0}
        .total-row
          span.total-label Amount Paid
          span UGX #{sale.amountPaid ? sale.amountPaid.toLocaleString() : 0}
        .total-row
          span.total-label Change
          span UGX #{sale.change ? sale.change.toLocaleString() : 0}
        .total-row
          span.total-label Payment Method
          span #{sale.paymentMethod}
      
      .footer-note
        p Thank you for choosing Nyondo Hardware!
        p.rule Transport is calculated as: Free delivery within 10km when total is 500,000 UGX or more. Otherwise 30,000 UGX.
        p For inquiries, call +256 712 345 678
    
    .text-center.p-3.no-print
      a.btn-gold(href='/newsale') New Sale
      a.btn-secondary.ms-2(href='/newsale') Back to Sales
      button.btn-secondary.ms-2(onclick='window.print()') Print

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
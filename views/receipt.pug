doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Receipt
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

body
  .container.mt-4
    .card
      .card-header.text-center
        h4 NYONDO General Hardware LTD
        p Sale Receipt
      .card-body
        p
          strong Customer: #{sale.customerName}
        p
          strong Product: #{sale.productName}
        p
          strong Quantity: #{sale.quantity}
        p
          strong Unit Price: UGX #{sale.unitprice}
        p
          strong Transport Fee: UGX #{sale.transportFee}
        hr
        h5 Total: UGX #{sale.totalamount}
        p
          strong Amount Paid: UGX #{sale.amountPaid}
        p
          strong Change: UGX #{sale.change}
        p
          strong Payment Method: #{sale.paymentMethod}
        p
          strong Date: #{sale.createdAt ? sale.createdAt.toLocaleString() : new Date().toLocaleString()}
        
        hr
        .text-center
          a.btn.btn-gold(href='/newsale') New Sale
          a.btn.btn-secondary.ms-2(href='/newsale') Back to Sales
          button.btn.btn-secondary.ms-2(onclick='window.print()') Print

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock Inventory Management
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/inventory.css')
// Navbar
nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning(href='#') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link(href='#') Reports
        li.nav-item
          a.nav-link.text-danger(href='#') Back
// Inventory Management Section
.container.mt-4
  .card
    .card-header Inventory Management
    .card-body
      .input-group.mb-3
        input#searchInput.form-control.bg-dark.text-white.border-secondary(type='text' name='search' placeholder='Search products...')
        button#searchBtn.btn.btn-gold Search
      button.btn.btn-gold.mb-3(data-bs-toggle='modal' data-bs-target='#addProductModal')
        | Add New Product
      table.table.table-dark.table-striped
        thead
          tr
            th Product Name
            th Category
            th Price
            th Quantity
            th Status
            th Actions
        tbody#productTable
          tr
            td Hammer
            td Tools
            td UGX10
            td 50
            td In Stock
            td
              button.btn.btn-sm.btn-gold Edit
              button.btn.btn-sm.btn-danger Delete
          tr
            td Nails
            td Hardware
            td UGX2
            td 200
            td In Stock
            td
              button.btn.btn-sm.btn-gold Edit
              button.btn.btn-sm.btn-danger Delete
// Add Product Modal
#addProductModal.modal.fade(tabindex='-1' aria-labelledby='addProductModalLabel' aria-hidden='true')
  .modal-dialog
    .modal-content.bg-dark.text-white
      .modal-header
        h5#addProductModalLabel.modal-title.text-warning
          | Add New Product
        button.btn-close.btn-close-white(type='button' data-bs-dismiss='modal' aria-label='Close')
      .modal-body
        form#addProductForm(action='inventorymgt' method='post')
          .mb-3
            label.form-label(for='productName') Product Name
            input#productName.form-control(type='text' name='productname' required='')
          .mb-3
            label.form-label(for='category') Category
            input#category.form-control(type='text' name='category' required='')
          .mb-3
            label.form-label(for='price') Price
            input#price.form-control(type='number' name='price' required='')
          .mb-3
            label.form-label(for='quantity') Quantity
            input#quantity.form-control(type='number' name='quantity' required='')
          button.btn.btn-gold(type='submit') Submit
          button.btn.btn-secondary(type='button' data-bs-dismiss='modal')
            | Cancel
// Bootstrap JS + Custom JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
//- script(src='/public/Js/inventory.js')

doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Manager Dashboard
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='css/dashboard.css')

nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='managerdashboard.html') NyondoStock Manager
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.active(href='#') Dashboard
        li.nav-item
          a.nav-link(href='add_stock') Register Stock
        li.nav-item
          a.nav-link(href='full-report.html') Reports
        li.nav-item
          a.nav-link.text-danger(href='/logout') Logout

.container-fluid.mt-4
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning Manager Dashboard
    .text-muted= new Date().toLocaleDateString()

  .row.g-4.mb-4
    .col-md-3
      .card.text-center
        .card-header.bg-transparent.border-0.pt-3
          h6 Total Products
        .card-body
          h3.text-warning= totalProducts || 0
          small.text-muted in inventory
    .col-md-3
      .card.text-center
        .card-header.bg-transparent.border-0.pt-3
          h6 Available Stock
        .card-body
          h3.text-info= totalStock || 0
          small.text-muted units remaining
    .col-md-3
      .card.text-center
        .card-header.bg-transparent.border-0.pt-3
          h6 Today's Sales
        .card-body
          h3.text-success UGX #{todaySales || 0}
          small.text-muted +12% from yesterday
    .col-md-3
      .card.text-center
        .card-header.bg-transparent.border-0.pt-3
          h6 Low Stock Alerts
        .card-body
          h3.text-danger= lowStockCount || 0
          small.text-muted needs attention

  // LOW STOCK ALERTS - FROM DATABASE
  .card.mb-4
    .card-header.d-flex.justify-content-between.align-items-center
      span Low Stock Alerts (View Only)
      span.badge.bg-danger Needs Reorder
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Product
              th Current Stock
              th Minimum Required
              th Action
          tbody
            if lowStockProducts && lowStockProducts.length > 0
              each product in lowStockProducts
                tr
                  td= product.productName
                  td
                    span.text-danger= product.quantity
                  td 50
                  td
                    a.btn.btn-sm.btn-gold(href=`/add_stock`) Request Reorder
            else
              tr
                td(colspan='4', class='text-center text-muted') No low stock items
      small.text-muted Note: Contact admin to approve reorders

  // PRODUCT MANAGEMENT - FIRST 5 PRODUCTS FROM DATABASE
  .card.mb-4
    .card-header.d-flex.justify-content-between.align-items-center
      span Product Management
      a.btn.btn-gold.btn-sm(href='add_stock') Register New Stock
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Product Name
              th Price (UGX)
              th Quantity
              th Status
              th Action
          tbody
            if recentProducts && recentProducts.length > 0
              each product in recentProducts
                tr
                  td= product.productName
                  td= 'UGX ' + product.sellingPrice.toLocaleString()
                  td
                    if product.quantity < 10
                      span.text-danger= product.quantity
                    else
                      = product.quantity
                  td
                    if product.quantity <= 0
                      span.badge.bg-danger Out of Stock
                    else if product.quantity < 10
                      span.badge.bg-danger Low Stock
                    else
                      span.badge.bg-success In Stock
                  td
                    a.btn.btn-sm.btn-gold(href=`/add_stock`) Manage
            else
              tr
                td(colspan='5', class='text-center text-muted') No products found

  // TODAY'S SALES MONITORING
  .card.mb-4
    .card-header
      span Today's Sales Monitoring
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Product
              th Quantity Sold
              th Total Amount (UGX)
              th Time
              th Sold By
          tbody
            if todaySalesList && todaySalesList.length > 0
              each sale in todaySalesList
                tr
                  td= sale.productName
                  td= sale.quantity
                  td= 'UGX ' + sale.totalamount.toLocaleString()
                  td= sale.createdAt ? sale.createdAt.toLocaleTimeString() : 'N/A'
                  td= sale.salespersonName || 'Unknown'
            else
              tr
                td(colspan='5', class='text-center text-muted') No sales today

  // REPORTS SECTION
  .card.mb-4
    .card-header.d-flex.justify-content-between.align-items-center
      span Reports
      a.btn.btn-sm.btn-gold(href='full-report.html') Generate Stock Report
    .card-body
      .mt-4
        .card-header Recent Activity
        .card-body(style='max-height: 200px; overflow-y: auto')
          ul.list-unstyled
            if recentActivities && recentActivities.length > 0
              each activity in recentActivities
                li.mb-2
                  strong= activity.user
                  | #{activity.action}
                  span.text-warning= activity.product
                  small.text-muted.float-end= activity.time
            else
              li.mb-2.text-muted No recent activity
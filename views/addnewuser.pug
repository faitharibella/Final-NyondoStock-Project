doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Add User - NyondoStock
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/newuser.css')
// Navbar
nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning(href='#') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link(href='#') Dashboard
        li.nav-item
          a.nav-link.active(href='#') Users
        li.nav-item
          a.nav-link(href='#') Reports
        li.nav-item
          a.nav-link(href='#') Records
        li.nav-item
          a.nav-link.text-danger(href='#') Logout
// Add User Form
.container
  .card
    .card-header Add New User
    .card-body
      form
        // Name
        .mb-3
          label.form-label(for='name') Full Name
          input#name.form-control(type='text' placeholder='Enter full name' required='')
        // Email
        .mb-3
          label.form-label(for='email') Email Address
          input#email.form-control(type='email' name='email' placeholder='Enter email' required='')
        // Role
        .mb-3
          label.form-label(for='role') Role
          select#role.form-select(required='')
            option(value='') Select role
            option(value='Manager') Manager
            option(value='Salesperson') Salesperson
        // Status
        .mb-3
          label.form-label(for='status') Status
          select#status.form-select(required='')
            option(value='') Select status
            option(value='Active') Active
            option(value='Inactive') Inactive
        // Password
        .mb-3
          label.form-label(for='password') Password
          input#password.form-control(type='password' name='password' placeholder='Enter password' required='')
        // Submit
        button.btn.btn-gold(type='submit') Add User
// Bootstrap JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')

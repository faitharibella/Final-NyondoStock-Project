doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Check Stock
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='#') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.text-danger(href='salesperson') Back

.container-fluid.mt-4
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning Check Available Stock
    .text-muted= new Date().toLocaleDateString()

  if error
    .alert.alert-danger= error

  .card
    .card-header Stock Inventory
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Product Name
              th Quantity Available
              th Selling Price (UGX)
          tbody
            if stocks && stocks.length > 0
              each stock in stocks
                tr
                  td= stock.productName
                  td
                    if stock.quantity <= 0
                      span.text-danger Out of Stock
                    else if stock.quantity < 10
                      span.text-warning= stock.quantity
                    else
                      = stock.quantity
                  td= 'UGX ' + stock.sellingPrice.toLocaleString()
            else
              tr
                td(colspan='3', class='text-center text-muted') No products available

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Stock Registration
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')
// Navbar
nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='#') NyondoStock Admin
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.text-danger(href='login.html') Logout
.container-fluid.mt-4
  // Page Header
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning  Stock Registration
    .text-muted May 6, 2026
  // Stock Registration Form
  .card.mb-4
    .card-header
      span  Register New Stock
    .card-body
      form#stockForm(action='add_stock' method='post')
        .row
          // Product Name Dropdown
          .col-md-6.mb-3
            label.form-label
              | Product Name 
              span.text-warning *
            select.form-select(name='productname')
              option(value='') -- Select Product --
              option(value='1') Cement - CEM IIN
              option(value='2') Cement - CEM III
              option(value='3') Iron Bars - 10mm
              option(value='4') Iron Bars - 12mm
              option(value='5') Iron Bars - 16mm
              option(value='6') Nails - 1 inch (5kg pack)
              option(value='7') Nails - 3 inch (5kg pack)
              option(value='8') Nails - 4 inch (5kg pack)
              option(value='9') Nails - 5 inch (5kg pack)
              option(value='10') Roofing Nails (5kg pack)
              option(value='11') Wheelbarrow
              option(value='12') Wire Mesh
              option(value='13') Barbed Wire - High Tensile
              option(value='14') Barbed Wire - Low Tensile
              option(value='15') Iron Sheets - Gauge 28 (Blue)
              option(value='16') Iron Sheets - Gauge 28 (Red)
              option(value='17') Iron Sheets - Gauge 28 (Green)
              option(value='18') Iron Sheets - Gauge 30 (Blue)
          // Quantity
          .col-md-3.mb-3
            label.form-label
              | Quantity 
              span.text-warning *
            input.form-control(type='number' name='quantity' placeholder='Number of units/bags/packs' required='')
          // Unit Cost
          .col-md-3.mb-3
            label.form-label
              | Unit Cost (UGX) 
              span.text-warning *
            input.form-control(type='number' name='unitCost' placeholder='Cost per unit' required='')
          // Selling Price
          .col-md-3.mb-3
            label.form-label
              | Selling Price (UGX) 
              span.text-warning *
            input.form-control(type='number' name='sellingPrice' placeholder='Price to sell' required='')
            small.text-muted Must be greater than unit cost
          // Supplier Name
          .col-md-3.mb-3
            label.form-label
              | Supplier Name 
              span.text-warning *
            input.form-control(type='text' name='supplierName' placeholder='Enter supplier name' required='')
          // Supplier Phone
          .col-md-3.mb-3
            label.form-label
              | Supplier Phone 
              span.text-warning *
            input.form-control(type='tel' name='supplierPhone' placeholder='+256 XXX XXX XXX' pattern='07[0-9]{8}' required='')
          // Factory Name
          .col-md-3.mb-3
            label.form-label Factory Name
            input.form-control(type='text' name='factoryName' placeholder='Factory/Depot name')
          // Payment Status
          .col-md-3.mb-3
            label.form-label
              | Payment Status 
              span.text-warning *
            select.form-select(name='paymentStatus' required='')
              option(value='cash') Cash at Hand
              option(value='credit') Credit (Pay Later)
          // Submit Buttons
          .col-md-12.mt-3
            button.btn.btn-gold(type='submit')  Save Stock Record
            button.btn.btn-secondary.ms-2(type='reset')  Reset Form
  // STOCK RECEIVED TABLE
  .card.mb-4
    .card-header.d-flex.justify-content-between
      span  Stock Received History
      button.btn.btn-sm.btn-gold(onclick='window.print()')  Print
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Date
              th Product
              th Quantity
              th Unit Cost
              th Selling Price
              th Total Paid
              th Payment Status
          tbody
            tr
              td 2026-05-01
              td Cement - CEM IIN
              td 500
              td UGX 28,000
              td UGX 32,000
              td UGX 14,000,000
              td
                span.badge.bg-success Cash
            tr
              td 2026-05-03
              td Iron Bars - 12mm
              td 300
              td UGX 35,000
              td UGX 42,000
              td UGX 10,500,000
              td
                span.badge.bg-warning.text-dark Credit
            tr
              td 2026-05-05
              td Roofing Nails
              td 100
              td UGX 18,000
              td UGX 22,000
              td UGX 1,800,000
              td
                span.badge.bg-success Cash
  // SUPPLIERS TABLE
  .card
    .card-header.d-flex.justify-content-between
      span &#x1F3ED; Supplier Records
      button.btn.btn-sm.btn-gold(onclick='window.print()')  Print
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Supplier Name
              th Phone
              th Factory/Depot
              th Products Supplied
              th Last Supply Date
              th Payment Status
          tbody
            tr
              td Hima Cement Ltd
              td 0772123456
              td Hima Factory
              td Cement CEM IIN, CEM III
              td 2026-05-01
              td
                span.badge.bg-success Paid
            tr
              td Roofings Ltd
              td 0414123456
              td Roofings Factory
              td Iron Bars, Iron Sheets
              td 2026-05-03
              td
                span.badge.bg-warning.text-dark Pending
            tr
              td Steel &amp; Wire Suppliers
              td 0755123456
              td Jinja Depot
              td Nails, Wire Mesh, Barbed Wire
              td 2026-05-05
              td
                span.badge.bg-success Paid

doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Products Management
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

// Navbar
nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning(href='#') NyondoStock - Products
    button.btn.btn-gold.ms-auto(onclick="window.location.href = 'admin'") Back

// Page Header
.container.mt-4
  h1.text-warning Products
  p.text-muted Browse and manage available products

// Success/Error Messages
if success
  .container.mt-2
    .alert.alert-success.alert-dismissible.fade-show
      = success
      button.btn-close(type='button' data-bs-dismiss='alert')
if error
  .container.mt-2
    .alert.alert-danger.alert-dismissible.fade-show
      = error
      button.btn-close(type='button' data-bs-dismiss='alert')

// Search + Add Product
.container.mb-3
  .row
    .col-md-8.mb-2
      form(action='/products/search' method='GET')
        .input-group
          input.form-control(type='text' name='search' placeholder='Search products by name...' value=searchTerm)
          button.btn.btn-gold(type='submit') Search
    .col-md-4.text-md-end
      button.btn.btn-gold(data-bs-toggle='modal' data-bs-target='#addProductModal') Add Product

// Products Table
.container
  .card
    .card-header All Products
    .card-body
      .table-responsive
        table.table.table-dark.table-striped
          thead
            tr
              th Product Name
              th Category
              th Price (UGX)
              th Quantity
              th Stock Status
              th Actions
          tbody
            if products && products.length > 0
              each product in products
                tr
                  td= product.productname
                  td= product.category
                  td= product.price.toLocaleString()
                  td
                    if product.quantity < 10
                      span.text-danger= product.quantity
                    else
                      = product.quantity
                  td
                    if product.quantity <= 0
                      span.badge.bg-danger Out of Stock
                    else if product.quantity < 10
                      span.badge.bg-warning.text-dark Low Stock
                    else
                      span.badge.bg-success In Stock
                  td
                    form(action='/products/delete' method='POST' style='display: inline-block;')
                      input(type='hidden' name='id' value=product._id)
                      button.btn.btn-sm.btn-danger(type='submit' onclick='return confirm("Are you sure?")') Delete
            else
              tr
                td(colspan='6', class='text-center text-muted') No products found. Click "Add Product" to create one.

// Add Product Modal
#addProductModal.modal.fade(tabindex='-1' aria-labelledby='addProductModalLabel' aria-hidden='true')
  .modal-dialog
    .modal-content.bg-dark.text-white
      .modal-header
        h5#addProductModalLabel.modal-title.text-warning Add New Product
        button.btn-close.btn-close-white(type='button' data-bs-dismiss='modal')
      .modal-body
        form(action='/products' method='POST')
          .mb-3
            label.form-label(for='productname') Product Name
            input#productname.form-control.bg-dark.text-white.border-secondary(type='text' name='productname' required)
          .mb-3
            label.form-label(for='category') Category
            select#category.form-select.bg-dark.text-white.border-secondary(name='category' required)
              option(value='') Select Category
              option(value='Hardware') Hardware
              option(value='Tools') Tools
              option(value='Paint') Paint
              option(value='Cement') Cement
              option(value='Nails') Nails
          .mb-3
            label.form-label(for='price') Price (UGX)
            input#price.form-control.bg-dark.text-white.border-secondary(type='number' name='price' required)
          .mb-3
            label.form-label(for='quantity') Quantity
            input#quantity.form-control.bg-dark.text-white.border-secondary(type='number' name='quantity' required)
          .modal-footer
            button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Cancel
            button.btn.btn-gold(type='submit') Save Product

// Bootstrap JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
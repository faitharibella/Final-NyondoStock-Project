doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0, user-scalable=yes')
  title NyondoStock - Sales Dashboard
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')

nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='#') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.active(href='#') Dashboard
        li.nav-item
          a.nav-link(href='newsale') New Sale
        li.nav-item
          a.nav-link(href='sales-history') Sales History
        li.nav-item
          a.nav-link(href='check-stock') Check Stock
        li.nav-item
          a.nav-link.text-danger(href='/logout') Logout

.container-fluid.mt-4
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning Welcome back, #{user ? user.fullname : 'Salesperson'}!
    .text-muted= new Date().toLocaleDateString()

  .row.g-4.mb-4
    .col-md-4
      .card.stat-card.text-center
        h6 Available Products
        .stat-number= totalProducts || 0
        small.text-muted in inventory
    .col-md-4
      .card.stat-card.text-center
        h6 Today's Sales
        .stat-number UGX #{todaySales || 0}
        small.text-muted from today
    .col-md-4
      .card.stat-card.text-center
        h6 My Commission (5%)
        .stat-number UGX #{commission || 0}
        small.text-muted this month

  .row
    .col-md-12
      .card
        .card-header Quick Actions
        .card-body
          .row
            .col-md-4.mb-2
              a.btn.btn-gold.w-100(href='newsale') Record New Sale
            .col-md-4.mb-2
              a.btn.btn-outline-gold.w-100(href='sales-history') View My Sales History
            .col-md-4.mb-2
              a.btn.btn-outline-gold.w-100(href='check-stock') Check Product Stock

  .card.mt-4
    .card-header.d-flex.justify-content-between.align-items-center
      span My Recent Sales
      a.btn.btn-sm.btn-gold(href='sales-history') View All
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Customer
              th Product
              th Quantity
              th Total Amount
              th Time
          tbody
            if recentSales && recentSales.length > 0
              each sale in recentSales
                tr
                  td= sale.customerName
                  td= sale.productName
                  td= sale.quantity
                  td= 'UGX ' + sale.totalamount.toLocaleString()
                  td= sale.createdAt ? sale.createdAt.toLocaleTimeString() : 'N/A'
            else
              tr
                td(colspan='5', class='text-center text-muted') No sales yet. Click "Record New Sale" to start.

  .card.mt-4
    .card-header Today's Tip
    .card-body
      p.mb-0 For credit sales, make sure the customer has enough deposit balance before processing.

script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
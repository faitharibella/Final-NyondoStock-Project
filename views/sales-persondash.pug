doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock - Sales Dashboard
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/dashboard.css')
// Navbar
nav.navbar.navbar-expand-lg
  .container-fluid
    a.navbar-brand.text-warning.fw-bold(href='sales-dashboard.html') NyondoStock
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav.ms-auto
        li.nav-item
          a.nav-link.active(href='#') Dashboard
        li.nav-item
          a.nav-link(href='newsale') New Sale
        li.nav-item
          a.nav-link(href='saleshistory.html') Sales History
        li.nav-item
          a.nav-link(href='check-stock') Check Stock
        li.nav-item
          a.nav-link.text-danger(href='/logout') Logout
.container-fluid.mt-4
  // Welcome Header
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.text-warning Welcome back, Sarah!
    .text-muted April 30, 2026
  // Stats Cards
  .row.g-4.mb-4
    .col-md-4
      .card.stat-card.text-center
        h6  Available Products
        .stat-number 45
        small.text-muted in inventory
    .col-md-4
      .card.stat-card.text-center
        h6  Today&apos;s Sales
        .stat-number UGX 245,000
        small.text-muted +12% from yesterday
    .col-md-4
      .card.stat-card.text-center
        h6  My Commission (5%)
        .stat-number UGX 12,250
        small.text-muted this month
  // Quick Actions Section
  .row
    .col-md-12
      .card
        .card-header  Quick Actions
        .card-body
          .row
            .col-md-4.mb-2
              a.btn.btn-gold.w-100(href='newsale')  Record New Sale
            .col-md-4.mb-2
              a.btn.btn-outline-gold.w-100(href='sales-history')  View My Sales History
            .col-md-4.mb-2
              a.btn.btn-outline-gold.w-100(href='check-stock')  Check Product Stock
  // Recent Sales Table
  .card.mt-4
    .card-header.d-flex.justify-content-between.align-items-center
      span  My Recent Sales
      a.btn.btn-sm.btn-gold(href='sales-history.html') View All
    .card-body
      .table-responsive
        table.table
          thead
            tr
              th Customer
              th Product
              th Quantity
              th Total Amount
              th Time
          tbody
            tr
              td
                | John Doe
              td
                | Hammer
              td
                | 2
              td
                | UGX 30,000
              td
                | 10:30 AM
            tr
              td
                | Mary Smith
              td
                | Nails (box)
              td
                | 5
              td
                | UGX 40,000
              td
                | 11:15 AM
            tr
              td
                | Peter Okoth
              td
                | Paint (tin)
              td
                | 3
              td
                | UGX 90,000
              td
                | 02:45 PM
  // Today's Tip
  .card.mt-4
    .card-header  Today&apos;s Tip
    .card-body
      p.mb-0
        | For credit sales, make sure the customer has enough deposit balance before processing.

doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock Salesperson Dashboard
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/salesperson.css')
// Navbar
nav.navbar.navbar-expand-lg.px-3
  a.navbar-brand.text-warning.fw-bold(href='#') NyondoStock
  button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#nav')
    span.navbar-toggler-icon
  #nav.collapse.navbar-collapse
    ul.navbar-nav.ms-auto.gap-3
      li.nav-item
        a.nav-link(href='#products') Products
      li.nav-item
        a.nav-link(href='#sales') Sales
      li.nav-item
        a.nav-link.text-danger.fw-bold(href='#') Logout
.container-fluid.mt-4
  // Dashboard Overview
  .row.g-3.mb-4
    .col-md-4
      .card.stat-card.text-center.p-3
        h6 Available Products
        h2 980
    .col-md-4
      .card.stat-card.text-center.p-3
        h6 Sales Today
        h2 45
    .col-md-4
      .card.stat-card.text-center.p-3
        h6 My Earnings
        h2 UGX 1,200
  // Product Viewing
  .card
    .card-header Available Products
    .card-body
      table.table.table-dark.table-hover.align-middle
        thead
          tr
            th Product
            th Price
            th Stock
        tbody
          tr
            td Hammer
            td UGX10
            td 50
          tr
            td Nails
            td UGX2
            td 200
  // Sales Function
  .card
    .card-header Record a Sale
    .card-body
      form
        .mb-3
          label.form-label(for='product') Product
          select#product.form-select(required='')
            option(value='') Select product
            option(value='Hammer') Hammer
            option(value='Nails') Nails
        .mb-3
          label.form-label(for='quantity') Quantity
          input#quantity.form-control(type='number' placeholder='Enter quantity' required='')
        button.btn.btn-gold(type='submit') Record Sale
      //
        <div class="mt-3">
        <p class="text-success">✔ Sale recorded successfully!</p>
        </div>
  // Sales Records
  .card
    .card-header My Recent Sales
    .card-body
      table.table.table-dark.table-striped
        thead
          tr
            th Product
            th Quantity
            th Total Amount
            th Date
        tbody
          tr
            td Hammer
            td 5
            td UGX50
            td 2026-04-21
          tr
            td Nails
            td 20
            td UGX40
            td 2026-04-22
// Bootstrap JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
// ! JS link
script(src='/Js/dashboard.js')

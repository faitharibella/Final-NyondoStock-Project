doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title NyondoStock Registration
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
  link(rel='stylesheet' href='/css/register.css')
.card
  h2 Register - NyondoStock
  form#registerForm(action='/registerpost' method='post')
    .mb-3
      label.form-label(for='fullName') Full Name
      input#fullName.form-control(type='text' name='fullname' required='')
    .mb-3
      label.form-label(for='email') Email Address
      input#email.form-control(type='email' name='email' required='')
    .mb-3
      label.form-label(for='password') Password
      input#password.form-control(type='text' name='password' placeholder='atleast 8 characters')
    .mb-3
      label.form-label(for='phone') Phone Number
      input#phone.form-control(type='tel' name='phone' placeholder='+256712345678')
    .mb-3
      label.form-label(for='nin') NIN (National ID)
      input#nin.form-control(type='text' name='nin' placeholder='Enter your NIN number')
    .mb-3
      label.form-label(for='role') Role
      select#role.form-select(name='role' type="text" required='')
        option(value='select user role') select user role 
        option(value='Salesperson') Salesperson
        option(value='Admin') Admin
        option(value='Manager') Manager
    button.btn.btn-gold(type='submit') Register
    #formMessage.message
// Bootstrap JS + Custom JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
